# ~/Library/Application Support/ai-server/.env
# Copy to .env and fill in. Never commit .env.
#
# ─── Auth ────────────────────────────────────────────────────────────
# This server authenticates via your Claude subscription (Max 5x).
# Before first run, on this machine:
#     claude login
# The runner verifies this on startup and refuses to start if unauth.
#
# DO NOT set ANTHROPIC_API_KEY — setting it would silently flip the SDK
# to API billing and ignore your subscription. The bootstrap script
# explicitly unsets it for all child processes.

# ─── Models ──────────────────────────────────────────────────────────
# Global default when a skill doesn't specify. Sonnet 4.6 for ~80% of
# work; skills that need Opus 4.7 declare it in their SKILL.md.
DEFAULT_MODEL=claude-sonnet-4-6

# ─── Database ────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://assistant:CHANGEME@localhost:5432/assistant

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Telegram ────────────────────────────────────────────────────────
# Create a bot via @BotFather; paste token here.
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric chat IDs. Get yours from @userinfobot.
TELEGRAM_ALLOWED_CHAT_IDS=

# ─── Web gateway ─────────────────────────────────────────────────────
# Random token: python -c 'import secrets; print(secrets.token_urlsafe(32))'
WEB_AUTH_TOKEN=

# Port for local FastAPI. Caddy reverse-proxies yourdomain.com → here.
WEB_PORT=8080

# ─── Paths ───────────────────────────────────────────────────────────
# Where the server lives. Avoid ~/Documents (macOS FDA blocks launchd).
SERVER_ROOT=/Users/chris/Library/Application Support/ai-server

# ─── Runner behavior ─────────────────────────────────────────────────
# Max 5x plan: 2 concurrent leaves headroom for your direct Claude use.
MAX_CONCURRENT_JOBS=2

# Max wall-clock per session (interrupt if exceeded).
SESSION_TIMEOUT_SECONDS=1800

# ─── Quota handling (subscription auth) ──────────────────────────────
# When the SDK surfaces a rate_limit / quota_exceeded signal, the runner
# pauses the queue for this many minutes before retrying. Real reset
# windows are preferred when the error carries one.
QUOTA_PAUSE_MINUTES=60

# ─── Domain ──────────────────────────────────────────────────────────
# Set after you register a domain via Cloudflare (Phase 3).
SERVER_DOMAIN=
